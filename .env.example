# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ELEVENLABS_API_KEY: Required for ElevenLabs Text-to-Speech.
# Users configure this via the Secrets panel in the AI Studio UI.
ELEVENLABS_API_KEY="MY_ELEVENLABS_API_KEY"

# STREAM_API_KEY: Required for Stream Video SDK.
VITE_STREAM_API_KEY="MY_STREAM_API_KEY"

# BACKEND_URL: The URL of your FastAPI backend.
VITE_BACKEND_URL="https://vision-commentator-549305467378.us-central1.run.app"
